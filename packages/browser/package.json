{
  "name": "@eyueldk/aisdk-toolkit-browser",
  "version": "2.0.0",
  "description": "Playwright browser toolkit (AI SDK tools) for the Vercel AI SDK",
  "license": "MIT",
  "author": "Eyuel G. Molla",
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
