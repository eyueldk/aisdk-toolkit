    "browser-automation",
    "tools",
    "agent",
    "playwright-alternative"
  ],
  "dependencies": {
    "ai": "^6.0.180",
    "puppeteer-core": "^24.43.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "@types/node": "^25.7.0",
    "dotenv": "^17.4.2",
    "tsdown": "^0.17.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6",
    "puppeteer": "^24.43.1"
  },
  "engines": {
    "node": ">=20"
  }
