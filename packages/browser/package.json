{
  "name": "@aitoolkit/browser",
  "version": "1.0.0",
  "description": "puppeteer-core browser tools for the Vercel AI SDK (bring your own Chromium)",
  "license": "MIT",
  "author": "Eyuel G. Molla",
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "module": "./dist/index.mjs",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/eyueldk/aitoolkit.git",
    "directory": "packages/browser"
  },
  "bugs": {
    "url": "https://github.com/eyueldk/aitoolkit/issues"
  },
  "homepage": "https://github.com/eyueldk/aitoolkit/tree/main/packages/browser#readme",
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "pnpm build",
    "check": "tsc --noEmit",
