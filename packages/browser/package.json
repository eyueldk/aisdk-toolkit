  },
  "devDependencies": {
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "@types/node": "^25.7.0",
    "@types/turndown": "^5.0.5",
    "dotenv": "^17.2.1",
    "tsdown": "^0.22.1",
    "tsx": "^4.21.0",
