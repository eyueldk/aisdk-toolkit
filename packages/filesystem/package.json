{
  "name": "@eyueldk/aisdk-toolkit-filesystem",
  "version": "1.2.0",
  "description": "FileSystem AI SDK tools with pluggable adapters for the Vercel AI SDK",
  "license": "MIT",
  "author": "Eyuel G. Molla",
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "module": "./dist/index.mjs",
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/eyueldk/aisdk-toolkit.git",
    "directory": "packages/filesystem"
  },
  "bugs": {
    "url": "https://github.com/eyueldk/aisdk-toolkit/issues"
  },
  "homepage": "https://github.com/eyueldk/aisdk-toolkit/tree/main/packages/filesystem#readme",
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "pnpm check && pnpm build",
    "check": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "eyueldk",
    "aisdk-toolkit",
    "@eyueldk/aisdk-toolkit-filesystem",
    "ai-sdk",
    "vercel-ai-sdk",
    "filesystem",
    "tools",
    "agents"
  ],
  "dependencies": {
    "@daytonaio/sdk": "0.183.0",
    "ai": "^6.0.180",
    "dockerode": "4.0.9",
    "memfs": "4.57.2",
    "minimatch": "^10.0.1",
    "pathe": "^2.0.3",
    "safe-regex2": "^5.1.1",
    "tar-stream": "3.1.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "@types/dockerode": "4.0.1",
    "@types/node": "^25.7.0",
    "@types/tar-stream": "3.1.4",
    "dotenv": "^17.2.1",
    "testcontainers": "^12.0.0",
    "tsdown": "^0.22.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=20"
  }
}
