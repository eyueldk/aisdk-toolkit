{
  "name": "@eyueldk/aisdk-toolkit",
  "private": true,
  "description": "Monorepo root for @eyueldk/aisdk-toolkit-* workspace packages",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/eyueldk/aisdk-toolkit.git"
  },
  "bugs": {
    "url": "https://github.com/eyueldk/aisdk-toolkit/issues"
  },
  "homepage": "https://github.com/eyueldk/aisdk-toolkit",
  "scripts": {
    "build": "pnpm --filter \"./packages/**\" run build",
    "check": "pnpm --filter \"./packages/**\" run check",
    "test": "pnpm -F @eyueldk/aisdk-toolkit-browser test && pnpm -F @eyueldk/aisdk-toolkit-todos test && pnpm -F @eyueldk/aisdk-toolkit-filesystem test && pnpm -F @eyueldk/aisdk-toolkit-shell test && pnpm -F @eyueldk/aisdk-toolkit-fetch test"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "cpu-features",
      "esbuild",
      "protobufjs",
      "puppeteer",
      "ssh2"
    ]
  },
  "packageManager": "pnpm@11.1.0"
}
